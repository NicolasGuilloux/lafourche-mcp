# Copy to .env, then fill in. Loaded by `docker compose` (env_file) and by
# `source .env`. Everything is optional — search works without any of this; only
# authenticated commands (orders, basket, info) need credentials.

# ── Authentication (headless Firebase email/password) ─────────────────────────
# Provide these to log in automatically (CLI prompt is skipped, container
# auto-logs-in on start). Required for orders / basket / info.
LAFOURCHE_EMAIL=
LAFOURCHE_PASSWORD=

# ── Container session ─────────────────────────────────────────────────────────
# Reuse a configured host's session instead of logging in inside the container:
# point this at a host config dir that has already run `lafourche login`.
# Leave empty to use a self-contained named volume (+ LAFOURCHE_EMAIL/PASSWORD).
#   macOS: $HOME/Library/Application Support/lafourche
#   Linux: $HOME/.config/lafourche
LAFOURCHE_CONFIG_DIR=

# ── Optional overrides (sane defaults otherwise) ──────────────────────────────
# MCP HTTP listen address.
# MCP_ADDR=:8080

# Member API endpoint (orders + cart price enrichment).
# LAFOURCHE_MEMBER_API_URL=https://api.lafourche.fr/graphql

# Firestore project that holds the account cart.
# LAFOURCHE_FIREBASE_PROJECT_ID=production-la-fourche
